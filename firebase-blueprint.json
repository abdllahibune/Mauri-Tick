{
  "entities": {
    "StoreConfig": {
      "title": "Store Configuration",
      "description": "Global settings for the store.",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "tagline": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "logoUrl": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" },
        "heroBackgroundColor": { "type": "string" },
        "themeColors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "accent": { "type": "string" },
            "background": { "type": "string" },
            "navbar": { "type": "string" },
            "button": { "type": "string" }
          }
        },
        "maintenanceMode": { "type": "boolean" },
        "aboutUs": { "type": "string" },
        "footerText": { "type": "string" },
        "adminPassword": { "type": "string" },
        "wheelSettings": {
          "type": "object",
          "properties": {
            "isActive": { "type": "boolean" },
            "prizes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "text": { "type": "string" },
                  "type": { "type": "string", "enum": ["percent", "fixed", "shipping", "gift"] },
                  "value": { "type": "number" },
                  "probability": { "type": "number" },
                  "color": { "type": "string" }
                }
              }
            },
            "totalSpins": { "type": "integer" },
            "totalCodesUsed": { "type": "integer" }
          }
        },
        "socialLinks": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "tiktok": { "type": "string" }
          }
        },
        "investorPopup": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "minInvestment": { "type": "string" },
            "isActive": { "type": "boolean" }
          }
        },
        "verificationMode": { "type": "string", "enum": ["whatsapp", "email", "manual"] }
      }
    },
    "Product": {
      "title": "Product",
      "description": "A mobile phone or accessory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "stock": { "type": "integer" },
        "description": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "specifications": {
          "type": "object",
          "properties": {
            "screen": { "type": "string" },
            "processor": { "type": "string" },
            "ram": { "type": "string" },
            "storage": { "type": "string" },
            "battery": { "type": "string" },
            "camera": { "type": "string" },
            "os": { "type": "string" },
            "colors": { "type": "string" }
          }
        },
        "isFeatured": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "soldCount": { "type": "integer" },
        "viewCount": { "type": "integer" },
        "suggestedAccessories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bundleAccessoryIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "UsedProduct": {
      "title": "Used Product",
      "description": "Customer-listed used products for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "sellerPhone": { "type": "string" },
        "condition": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TradeIn": {
      "title": "Trade-In Request",
      "description": "Requests to trade in old phones for new ones.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "oldPhoneModel": { "type": "string" },
        "condition": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "estimatedValue": { "type": "number" },
        "targetPhoneId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Investor": {
      "title": "Investor Inquiry",
      "description": "Potential partner/investor leads.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "amount": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" },
              "image": { "type": "string" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["بنكيلي", "سداد", "مصرفي"] },
        "paymentProofUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["قيد الانتظار", "تم التأكيد", "تم الشحن", "تم التسليم"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "total", "paymentMethod", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount codes.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percent", "fixed"] },
        "value": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "integer" },
        "usageCount": { "type": "integer" },
        "isActive": { "type": "boolean" }
      }
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Visitor and revenue stats per day.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "visitors": { "type": "integer" },
        "revenue": { "type": "number" },
        "orders": { "type": "integer" }
      }
    },
    "User": {
      "title": "User",
      "description": "A customer profile.",
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "password": { "type": "string" },
        "totalSpent": { "type": "number" },
        "ordersCount": { "type": "integer" },
        "isVerified": { "type": "boolean" },
        "verificationCode": { "type": "string" },
        "wishlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phone", "password"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "isHidden": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupportRequest": {
      "title": "Support Request",
      "description": "A support or contact inquiry.",
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "name": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["chat", "contact_form"] },
        "status": { "type": "string", "enum": ["pending", "contacted", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "mt_users/{userId}": {
      "schema": "User",
      "description": "Customer profiles."
    },
    "mt_config/settings": {
      "schema": "StoreConfig",
      "description": "Store-wide configuration."
    },
    "mt_products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "mt_orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "mt_coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons."
    },
    "mt_stats/{dayId}": {
      "schema": "DailyStats",
      "description": "Daily statistics."
    },
    "mt_sell_listings/{listingId}": {
      "schema": "UsedProduct",
      "description": "Used products for sale."
    },
    "mt_tradein/{requestId}": {
      "schema": "TradeIn",
      "description": "Trade-in requests."
    },
    "mt_investors/{investorId}": {
      "schema": "Investor",
      "description": "Investor leads."
    },
    "mt_reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "mt_support_requests/{requestId}": {
      "schema": "SupportRequest",
      "description": "Support and contact requests."
    }
  }
}
