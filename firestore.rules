rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. THE MASTER GATE (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. PRIMITIVE HELPERS
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 3. COLLECTION RULES
    
    // Config & Theme
    match /config/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if (isAdmin() && isValidProduct(incoming())) 
                    || (incoming().diff(existing()).affectedKeys().hasOnly(['viewCount', 'soldCount']));
      allow delete: if isAdmin();
      
      function isValidProduct(p) {
        return p.name is string && p.name.size() > 0 && p.name.size() < 200
               && p.price is number && p.price >= 0
               && p.brand is string && p.brand.size() > 0;
      }
    }

    // Users (Customers)
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // During registration, we allow create but validate
      allow create: if true; 
      allow update: if (isAdmin()) || (isSignedIn() && request.auth.uid == userId && !incoming().diff(existing()).affectedKeys().hasAny(['phone', 'isBlocked']));
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow get: if true; 
      allow list: if isAdmin() || (request.query.limit <= 50 && request.query.offset == 0); 
      allow update: if isAdmin();
      allow delete: if isAdmin();

      function isValidOrder(o) {
        return o.customerName is string && o.customerName.size() > 0
               && o.phone is string && o.phone.size() == 8
               && o.items is list && o.items.size() > 0;
      }
    }

    // Coupons
    match /coupons/{couponCode} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // System only or manual
    }
  }
}
